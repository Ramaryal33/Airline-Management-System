<%@ page contentType="text/html;charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>${pageTitle}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { display: flex; margin: 0; font-family: Arial, sans-serif; }
    nav.sidebar {
      width: 200px; background: #2c3e50; color: #ecf0f1;
      padding: 20px; height: 100vh; box-sizing: border-box;
    }
    nav.sidebar h2 { margin-top: 0; color: #ecf0f1; }
    nav.sidebar a {
      display: block; color: #bdc3c7; text-decoration: none;
      margin: 10px 0; padding: 5px; border-radius: 4px;
    }
    nav.sidebar a:hover { background: #34495e; color: white; }
    main.content {
      flex: 1; padding: 20px; background: #ecf0f1;
      overflow-y: auto; height: 100vh; box-sizing: border-box;
    }
    .cards { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 30px; }
    .card {
      background: white; padding: 15px; border-radius: 6px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      flex: 1 1 150px; text-align: center;
    }
    .card h3 { margin: 0 0 10px; font-size: 16px; color: #2c3e50; }
    .card p { font-size: 20px; margin: 0; }
    .charts { display: flex; flex-wrap: wrap; gap: 30px; }
    .chart-box {
      background: white; padding: 15px; border-radius: 6px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      flex: 1 1 300px;
    }
    table {
      width: 100%; border-collapse: collapse; background: white;
      margin-top: 20px; border-radius: 6px; overflow: hidden;
    }
    th, td {
      padding: 8px; border-bottom: 1px solid #ddd; text-align: left;
    }
    th { background: #3498db; color: white; }
  </style>
</head>
<body>

<nav class="sidebar">
  <h2>Dawn Airlines</h2>
  <a href="staffDashboard">Dashboard</a>
  <a href="#">Staff</a>
  <a href="#">Attendance</a>
  <a href="#">Tasks</a>
  <a href="#">Performance</a>
  <a href="#">Flights</a>
  <a href="#">Passengers</a>
  <a href="logout">Logout</a>
</nav>

<main class="content">
  <h1>${pageTitle}</h1>

  <!-- Summary Cards -->
  <div class="cards">
    <div class="card"><h3>Total Hours</h3><p><fmt:formatNumber value="${totalHours}" maxFractionDigits="2"/></p></div>
    <div class="card"><h3>Active Tasks</h3><p>${activeTasks}</p></div>
    <div class="card"><h3>Pending Tasks</h3><p>${pendingTasks}</p></div>
    <div class="card"><h3>Avg Rating</h3><p><fmt:formatNumber value="${avgRating}" maxFractionDigits="1"/>%</p></div>
    <div class="card"><h3>Total Flights</h3><p>${totalFlights}</p></div>
    <div class="card"><h3>Total Passengers</h3><p>${totalPassengers}</p></div>
  </div>

  <!-- Charts -->
  <div class="charts">
    <div class="chart-box">
      <h3>Task Status Distribution</h3>
      <canvas id="taskChart"></canvas>
    </div>
    <div class="chart-box">
      <h3>Performance Distribution</h3>
      <canvas id="perfChart"></canvas>
    </div>
  </div>

  <!-- Recent Attendance -->
  <h2>Recent Attendance</h2>
  <table>
    <tr><th>Date</th><th>Clock In</th><th>Clock Out</th><th>Status</th><th>Hours</th></tr>
    <c:forEach var="a" items="${recentAttendance}">
      <tr>
        <td><fmt:formatDate value="${a.date}" pattern="yyyy-MM-dd"/></td>
        <td><fmt:formatDate value="${a.clockIn}" pattern="HH:mm"/></td>
        <td><fmt:formatDate value="${a.clockOut}" pattern="HH:mm"/></td>
        <td>${a.status}</td>
        <td><fmt:formatNumber value="${a.workingHours}" maxFractionDigits="2"/></td>
      </tr>
    </c:forEach>
  </table>

  <!-- Upcoming Flights -->
  <h2>Upcoming Flights</h2>
  <table>
    <tr><th>Flight #</th><th>Airline</th><th>From→To</th><th>Departure</th><th>Arrival</th></tr>
    <c:forEach var="f" items="${upcomingFlights}">
      <tr>
        <td>${f.flightNumber}</td>
        <td>${f.airline}</td>
        <td>${f.source}→${f.destination}</td>
        <td><fmt:formatDate value="${f.departureTime}" pattern="yyyy-MM-dd HH:mm"/></td>
        <td><fmt:formatDate value="${f.arrivalTime}" pattern="yyyy-MM-dd HH:mm"/></td>
      </tr>
    </c:forEach>
  </table>

  <!-- Recent Passengers -->
  <h2>Recent Passengers</h2>
  <table>
    <tr><th>ID</th><th>Name</th><th>Email</th><th>Phone</th><th>Passport No.</th></tr>
    <c:forEach var="p" items="${recentPassengers}">
      <tr>
        <td>${p.id}</td>
        <td>${p.fullName}</td>
        <td>${p.email}</td>
        <td>${p.phoneNumber}</td>
        <td>${p.passportNo}</td>
      </tr>
    </c:forEach>
  </table>

  <script>
    // Task Status Bar Chart
    const taskLabels = [<c:forEach var="key" items="${taskStatusCounts.keySet()}">'${key}',</c:forEach>];
    const taskData = [<c:forEach var="val" items="${taskStatusCounts.values()}">${val},</c:forEach>];

    new Chart(document.getElementById('taskChart'), {
      type: 'bar',
      data: {
        labels: taskLabels,
        datasets: [{
          label: 'Tasks',
          data: taskData,
          backgroundColor: ['#3498db','#f1c40f','#e67e22','#e74c3c']
        }]
      },
      options: {
        scales: { y: { beginAtZero: true, stepSize: 1 } }
      }
    });

    // Performance Pie Chart
    const perfLabels = [<c:forEach var="key" items="${performanceDistribution.keySet()}">'${key}',</c:forEach>];
    const perfData = [<c:forEach var="val" items="${performanceDistribution.values()}">${val},</c:forEach>];

    new Chart(document.getElementById('perfChart'), {
      type: 'pie',
      data: {
        labels: perfLabels,
        datasets: [{ data: perfData, backgroundColor: ['#2ecc71','#f39c12','#e74c3c','#95a5a6'] }]
      }
    });
  </script>

</main>
</body>
</html>
