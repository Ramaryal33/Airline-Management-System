package com.airline.controller;

import com.airline.model.User;
import com.airline.staff.service.*;
import com.airline.staff.model.*;
import com.airline.util.SessionUtil;
import jakarta.servlet.*;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.*;
import java.io.IOException;
import java.util.List;

@WebServlet("/staffDashboard")
public class StaffDashboardController extends HttpServlet {
    
    private AttendanceService attendanceService;
    private FlightService flightService;
    private PerformanceReviewService performanceReviewService;
    private StaffService staffService;
    private TaskService taskService;
    
    @Override
    public void init() throws ServletException {
        super.init();
        attendanceService = new AttendanceService();
        flightService = new FlightService();
        performanceReviewService = new PerformanceReviewService();
        staffService = new StaffService();
        taskService = new TaskService();
    }

    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        User loggedUser = SessionUtil.getLoggedUser(request);

        // Check authentication and authorization
        if (loggedUser == null || !"staff".equalsIgnoreCase(loggedUser.getUserType())) {
            response.sendRedirect(request.getContextPath() + "/login");
            return;
        }

        try {
            // Get all data for dashboard
            List<Attendance> attendances = attendanceService.getAllAttendances();
            List<Flight> flights = flightService.getAllFlights();
            List<PerformanceReview> reviews = performanceReviewService.getAllReviews();
            List<Staff> staffList = staffService.getAllStaff();
            List<Task> tasks = taskService.getAllTasks();
            
            // Calculate metrics for dashboard
            int totalFlights = flights.size();
            int totalStaff = staffList.size();
            int completedTasks = (int) tasks.stream().filter(t -> "Completed".equalsIgnoreCase(t.getStatus())).count();
            int pendingTasks = tasks.size() - completedTasks;
            
            // Get current staff member's data
            Staff currentStaff = staffService.getStaffById(loggedUser.getUserId());
            
            // Set attributes for JSP
            request.setAttribute("attendances", attendances);
            request.setAttribute("flights", flights);
            request.setAttribute("reviews", reviews);
            request.setAttribute("staffList", staffList);
            request.setAttribute("tasks", tasks);
            request.setAttribute("totalFlights", totalFlights);
            request.setAttribute("totalStaff", totalStaff);
            request.setAttribute("completedTasks", completedTasks);
            request.setAttribute("pendingTasks", pendingTasks);
            request.setAttribute("currentStaff", currentStaff);
            request.setAttribute("loggedUser", loggedUser);
            
            // Forward to JSP
            request.getRequestDispatcher("/WEB-INF/page/staffDashboard.jsp").forward(request, response);
            
        } catch (Exception e) {
            e.printStackTrace();
            request.setAttribute("error", "Error loading dashboard data");
            request.getRequestDispatcher("/WEB-INF/page/error.jsp").forward(request, response);
        }
    }
}