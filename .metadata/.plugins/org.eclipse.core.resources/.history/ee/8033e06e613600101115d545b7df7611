package com.airline.service;

import com.airline.model.Flight;
import com.airline.config.DbConfig;

import java.sql.*;
import java.time.LocalDate;
import java.time.LocalTime;
import java.util.ArrayList;
import java.util.List;

/**
 * Handles all flight-related database operations:
 * - Add Flight (admin)
 * - Get Flight by ID
 * - Search Flights (by flightId, or by route/date/class)
 * - List all flights (for search results)
 */
public class FlightService {

    /**
     * Adds a new flight to the database.
     */
    public boolean addFlight(Flight flight) throws SQLException {
        String sql = """
            INSERT INTO flights
              (flight_id, from_city, to_city, departure_date, departure_time, travel_class, price)
            VALUES (?, ?, ?, ?, ?, ?, ?)
            """;
        try (Connection conn = DBConfig.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, flight.getFlightId());
            ps.setString(2, flight.getFromCity());
            ps.setString(3, flight.getToCity());
            ps.setDate(4, Date.valueOf(flight.getDepartureDate()));
            ps.setTime(5, Time.valueOf(flight.getDepartureTime()));
            ps.setString(6, flight.getTravelClass());
            ps.setDouble(7, flight.getPrice());

            return ps.executeUpdate() > 0;
        }
    }

    /**
     * Retrieves a flight by its ID.
     */
    public Flight getFlightById(String flightId) throws SQLException {
        String sql = """
            SELECT flight_id, from_city, to_city, departure_date, departure_time, travel_class, price
            FROM flights
            WHERE flight_id = ?
            """;
        try (Connection conn = DbConfig.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, flightId);
            try (ResultSet rs = ps.executeQuery()) {
                if (rs.next()) {
                    Flight f = new Flight();
                    f.setFlightId(rs.getString("flight_id"));
                    f.setFromCity(rs.getString("from_city"));
                    f.setToCity(rs.getString("to_city"));
                    f.setDepartureDate(rs.getDate("departure_date").toLocalDate());
                    f.setDepartureTime(rs.getTime("departure_time").toLocalTime());
                    f.setTravelClass(rs.getString("travel_class"));
                    f.setPrice(rs.getDouble("price"));
                    return f;
                }
            }
        }
        return null;
    }

    /**
     * Returns all flights (used for simple listing).
     */
    public List<Flight> getAllFlights() throws SQLException {
        List<Flight> list = new ArrayList<>();
        String sql = """
            SELECT flight_id, from_city, to_city, departure_date, departure_time, travel_class, price
            FROM flights
            ORDER BY departure_date, departure_time
            """;
        try (Connection conn = DbConfig.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql);
             ResultSet rs = ps.executeQuery()) {

            while (rs.next()) {
                Flight f = new Flight();
                f.setFlightId(rs.getString("flight_id"));
                f.setFromCity(rs.getString("from_city"));
                f.setToCity(rs.getString("to_city"));
                f.setDepartureDate(rs.getDate("departure_date").toLocalDate());
                f.setDepartureTime(rs.getTime("departure_time").toLocalTime());
                f.setTravelClass(rs.getString("travel_class"));
                f.setPrice(rs.getDouble("price"));
                list.add(f);
            }
        }
        return list;
    }

    /**
     * Searches flights by optional filters: flightId, from, to, departureDate, travelClass.
     * If flightId is nonempty, returns flights matching that ID.
     * Otherwise, filters by route/date/class if provided.
     */
    public List<Flight> searchFlights(String flightId,
                                      String fromCity,
                                      String toCity,
                                      String departureDateStr,
                                      String travelClass) throws SQLException {
        List<Flight> list = new ArrayList<>();
        StringBuilder sb = new StringBuilder();
        sb.append("""
            SELECT flight_id, from_city, to_city, departure_date, departure_time, travel_class, price
            FROM flights
            WHERE 1=1
            """);

        List<Object> params = new ArrayList<>();

        if (flightId != null && !flightId.isBlank()) {
            sb.append(" AND flight_id = ?");
            params.add(flightId);
        }
        if (fromCity != null && !fromCity.isBlank()) {
            sb.append(" AND from_city LIKE ?");
            params.add("%" + fromCity + "%");
        }
        if (toCity != null && !toCity.isBlank()) {
            sb.append(" AND to_city LIKE ?");
            params.add("%" + toCity + "%");
        }
        if (departureDateStr != null && !departureDateStr.isBlank()) {
            sb.append(" AND departure_date = ?");
            params.add(Date.valueOf(departureDateStr));
        }
        if (travelClass != null && !travelClass.isBlank()) {
            sb.append(" AND travel_class = ?");
            params.add(travelClass);
        }

        sb.append(" ORDER BY departure_date, departure_time");

        try (Connection conn = DbConfig.getConnection();
             PreparedStatement ps = conn.prepareStatement(sb.toString())) {

            for (int i = 0; i < params.size(); i++) {
                ps.setObject(i + 1, params.get(i));
            }

            try (ResultSet rs = ps.executeQuery()) {
                while (rs.next()) {
                    Flight f = new Flight();
                    f.setFlightId(rs.getString("flight_id"));
                    f.setFromCity(rs.getString("from_city"));
                    f.setToCity(rs.getString("to_city"));
                    f.setDepartureDate(rs.getDate("departure_date").toLocalDate());
                    f.setDepartureTime(rs.getTime("departure_time").toLocalTime());
                    f.setTravelClass(rs.getString("travel_class"));
                    f.setPrice(rs.getDouble("price"));
                    list.add(f);
                }
            }
        }
        return list;
    }
}
