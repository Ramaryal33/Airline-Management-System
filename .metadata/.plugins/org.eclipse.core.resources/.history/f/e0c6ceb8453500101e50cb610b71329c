    private final FlightService service = new FlightService();

    @Override
    protected void doGet(HttpServletRequest req, HttpServletResponse resp) throws ServletException, IOException {
        String action = req.getParameter("action");

        if ("edit".equals(action)) {
            int id = Integer.parseInt(req.getParameter("id"));
            Flight flight = service.getFlightById(id);
            req.setAttribute("flight", flight);
        } else if ("delete".equals(action)) {
            int id = Integer.parseInt(req.getParameter("id"));
            service.deleteFlight(id);
            resp.sendRedirect("flight");
            return;
        }

        List<Flight> list = service.getAllFlights();
        req.setAttribute("flightList", list);
        req.getRequestDispatcher("flight.jsp").forward(req, resp); // ✅ Unified JSP
    }

