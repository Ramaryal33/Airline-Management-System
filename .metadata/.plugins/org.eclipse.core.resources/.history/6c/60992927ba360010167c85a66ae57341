<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Search Flights - Dawn Airlines</title>
  <style>
    /* ─── RESET & BASE STYLES ─────────────────────────────────────────────────── */
    * {
      margin: 0; padding: 0; box-sizing: border-box;
      font-family: 'Open Sans', Arial, sans-serif;
    }
    body {
      background: #f7f9fc;
      color: #333;
      padding: 20px;
    }
    h2 {
      margin-bottom: 20px;
      color: #2c3e50;
    }

    /* ─── SEARCH FORM ─────────────────────────────────────────────────────────── */
    .search-form {
      margin-bottom: 20px;
    }
    .search-form input[type="text"] {
      padding: 8px;
      border: 1px solid #ccc;
      border-radius: 4px;
      font-size: 1rem;
      width: 200px;
    }
    .search-form button {
      padding: 8px 16px;
      background: #1976d2;
      color: #fff;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 1rem;
      transition: background 0.3s;
    }
    .search-form button:hover {
      background: #145ca8;
    }

    /* ─── TABLE STYLES ────────────────────────────────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }
    th, td {
      padding: 12px;
      border: 1px solid #ddd;
      text-align: left;
    }
    th {
      background: #ecf0f1;
      font-weight: bold;
    }
    tr:hover {
      background: #f1f1f1;
    }

    /* ─── BOOK FORM ───────────────────────────────────────────────────────────── */
    .book-form input[type="number"] {
      width: 60px;
      padding: 4px;
      margin-right: 8px;
      border: 1px solid #ccc;
      border-radius: 4px;
    }
    .book-form button {
      background: #28a745;
      color: #fff;
      border: none;
      padding: 6px 12px;
      border-radius: 4px;
      cursor: pointer;
      transition: background 0.3s;
    }
    .book-form button:hover {
      background: #1e7e34;
    }

    /* ─── EMPTY MESSAGE ───────────────────────────────────────────────────────── */
    .empty-message {
      text-align: center;
      color: #555;
      margin-top: 20px;
      font-size: 1rem;
    }
  </style>
</head>
<body>
  <h2>Available Flights</h2>

  <!-- Search form on this page also posts to /flight -->
  <form class="search-form" action="${pageContext.request.contextPath}/flight" method="post">
    Flight #: 
    <input 
      type="text" 
      name="flightId" 
      placeholder="e.g. NP100"
      value="${fn:escapeXml(param.flightId)}" 
    />
    <button type="submit">Search</button>
  </form>

  <!-- Flights table -->
  <c:if test="${not empty flights}">
    <table>
      <thead>
        <tr>
          <th>Flight #</th>
          <th>Route</th>
          <th>Date</th>
          <th>Time</th>
          <th>Class</th>
          <th>Price</th>
          <th>Book</th>
        </tr>
      </thead>
      <tbody>
        <c:forEach var="f" items="${flights}">
          <tr>
            <td><c:out value="${f.flightId}" /></td>
            <td><c:out value="${f.fromCity}" /> → <c:out value="${f.toCity}" /></td>
            <td>
              <fmt:formatDate value="${f.departureDate}" pattern="MMM dd, yyyy" />
            </td>
            <td>
              <fmt:formatDate value="${f.departureTime}" pattern="hh:mm a" />
            </td>
            <td><c:out value="${f.travelClass}" /></td>
            <td>
              <fmt:formatNumber value="${f.price}" type="currency" currencySymbol="NPR " />
            </td>
            <td>
              <form class="book-form" 
                    action="${pageContext.request.contextPath}/createBooking" 
                    method="post">
                <input type="hidden" name="flightId" value="${f.flightId}" />
                Seats: <input type="number" name="numOfPassengers" value="1" min="1" required />
                <button type="submit">Book</button>
              </form>
            </td>
          </tr>
        </c:forEach>
      </tbody>
    </table>
  </c:if>

  <c:if test="${empty flights}">
    <div class="empty-message">
      No flights found.
    </div>
  </c:if>
</body>
</html>
