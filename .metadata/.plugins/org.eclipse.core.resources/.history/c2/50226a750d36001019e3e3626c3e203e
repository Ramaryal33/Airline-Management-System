        if (loggedUser == null || !"staff".equalsIgnoreCase(loggedUser.getUserType())) {
            response.sendRedirect(request.getContextPath() + "/login");
            return;
        }

        // Get staff ID from session or logged user
        int staffId = getStaffIdFromSession(loggedUser);
        
        // Set dashboard data
        request.setAttribute("attendanceRecords", attendanceService.getAllAttendances());
        request.setAttribute("flights", flightService.getAllFlights());
        request.setAttribute("performanceReviews", performanceService.getAllReviews());
        request.setAttribute("staffMembers", staffService.getAllStaff());
        request.setAttribute("tasks", taskService.getAllTasks());
        
        // Statistics for dashboard
        request.setAttribute("totalFlights", flightService.getAllFlights().size());
        request.setAttribute("totalStaff", staffService.getAllStaff().size());
        request.setAttribute("totalTasks", taskService.getAllTasks().size());
        
        // Bar graph data (sample data - you should replace with real data)
        request.setAttribute("monthlyFlightData", getMonthlyFlightData());
        request.setAttribute("taskStatusData", getTaskStatusData());

        request.getRequestDispatcher("/WEB-INF/page/staffDashboard.jsp").forward(request, response);
    }

