<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Dawn Airlines</title>
    <style>
        /* ────────── Reset & Base ────────── */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Open Sans', Arial, sans-serif;
        }
        body {
            background: #f7f9fc;
            color: #333;
            padding: 20px;
        }
        h1, h2, h3 {
            color: #2c3e50;
            margin-bottom: 15px;
        }

        /* ────────── Search by Flight ────────── */
        .search-section {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 30px;
        }
        .search-section input[type="text"] {
            flex: 1;
            padding: 10px;
            border: 2px solid #ccc;
            border-radius: 6px;
        }
        .search-section button {
            padding: 10px 20px;
            border: none;
            background: #1976d2;
            color: #fff;
            border-radius: 6px;
            cursor: pointer;
            transition: background .3s;
        }
        .search-section button:hover {
            background: #145ca8;
        }

        /* ────────── Overview Table ────────── */
        .overview-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 15px;
        }
        .overview-table th, .overview-table td {
            padding: 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }
        .overview-table th {
            background: #ecf0f1;
        }

        /* ────────── Ticket Card ────────── */
        .ticket-card {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .ticket-card p {
            margin: 8px 0;
        }

        /* ────────── Flight Finder ────────── */
        .finder {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 30px;
        }
        .finder .trip-type {
            flex: 1 1 200px;
            display: flex;
            gap: 10px;
        }
        .finder .trip-type a {
            padding: 8px 16px;
            background: #ecf0f1;
            border-radius: 6px;
            text-decoration: none;
            color: #2c3e50;
            font-weight: 600;
            transition: background .3s;
        }
        .finder .trip-type a.active,
        .finder .trip-type a:hover {
            background: #1976d2;
            color: #fff;
        }
        .finder form {
            flex: 3 1 400px;
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        .finder .form-row {
            display: flex;
            gap: 15px;
            margin-bottom: 15px;
        }
        .finder .form-row input,
        .finder .form-row select {
            flex: 1;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }
        .finder form button {
            display: block;
            width: 100%;
            padding: 12px;
            border: none;
            background: #28a745;
            color: #fff;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            transition: background .3s, transform .2s;
        }
        .finder form button:hover {
            background: #1e7e34;
            transform: scale(1.02);
        }

        /* ────────── Responsive ────────── */
        @media (max-width: 768px) {
            .finder, .search-section {
                flex-direction: column;
            }
            .finder .trip-type {
                justify-content: space-around;
            }
        }
    </style>
</head>
<body>
    <!--───────────────────────────────────-->
    <!-- Welcome Header -->
    <!--───────────────────────────────────-->
    <h1>WELCOME, <c:out value="${sessionScope.user.fullName}" /></h1>

    <!--───────────────────────────────────-->
    <!-- Search by Flight No. -->
    <!--───────────────────────────────────-->
    <div class="search-section">
        <form id="overviewForm" action="${pageContext.request.contextPath}/searchFlight" method="get">
            <input type="text" name="flightId" placeholder="Search by Flight No." value="${param.flightId}" />
            <button type="submit">Search</button>
        </form>
    </div>

    <!--───────────────────────────────────-->
    <!-- Your Ticket Overview -->
    <!--───────────────────────────────────-->
    <h2>Your Ticket Overview</h2>
    <form id="overviewFormTable" action="${pageContext.request.contextPath}/searchFlight" method="get">
        <table class="overview-table">
            <thead>
                <tr>
                    <th>Flight Number</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                <c:forEach var="ticket" items="${requestScope.tickets}">
                    <tr>
                        <td><c:out value="${ticket.flightId}" /></td>
                        <td><c:out value="${ticket.departureDateFormatted}" /></td>
                    </tr>
                </c:forEach>
                <c:if test="${empty requestScope.tickets}">
                    <tr>
                        <td colspan="2" style="text-align:center; color:#555;">
                            No tickets found.
                        </td>
                    </tr>
                </c:if>
            </tbody>
        </table>
    </form>
    <c:forEach var="ticket" items="${requestScope.tickets}">
        <div class="ticket-card">
            <p><strong>Time:</strong> <c:out value="${ticket.departureTimeFormatted}" /></p>
            <p><strong>Class:</strong> <c:out value="${ticket.travelClass}" /></p>
        </div>
    </c:forEach>

    <hr />

    <!--───────────────────────────────────-->
    <!-- Find Your Flight (Quick Search) -->
    <!--───────────────────────────────────-->
    <h2>Find Your Flight</h2>
    <div class="finder">
        <div class="trip-type">
            <a href="#" class="active">One Way</a>
            <a href="#">Round Trip</a>
        </div>
        <form action="${pageContext.request.contextPath}/searchFlights" method="get">
            <div class="form-row">
                <input type="text" name="from" placeholder="From?" value="${param.from}" />
                <input type="text" name="to" placeholder="To?" value="${param.to}" />
            </div>
            <div class="form-row">
                <input type="date" name="departureDate" value="${param.departureDate}" />
                <input type="date" name="returnDate" value="${param.returnDate}" />
            </div>
            <div class="form-row">
                <select name="travelClass">
                    <option value="">Select Class</option>
                    <option value="Economy" ${param.travelClass == 'Economy' ? 'selected' : ''}>Economy</option>
                    <option value="Business" ${param.travelClass == 'Business' ? 'selected' : ''}>Business</option>
                </select>
                <input type="number" name="passengers" min="1" max="10" value="${param.passengers != null ? param.passengers : 1}" />
            </div>
            <button type="submit">Search Flights</button>
        </form>
    </div>

    <hr />

    <!--───────────────────────────────────-->
    <!-- Your Recent Ticket -->
    <!--───────────────────────────────────-->
    <h2>Your Ticket</h2>
    <h3>Your Recent Ticket</h3>
    <c:if test="${not empty requestScope.recentTicket}">
        <div class="ticket-card">
            <p><strong>Booking Ref:</strong> <c:out value="${recentTicket.bookingRef}" /></p>
            <p><strong>Flight No:</strong> <c:out value="${recentTicket.flightId}" /></p>
            <p><strong>Route:</strong> <c:out value="${recentTicket.fromCity}" /> → <c:out value="${recentTicket.toCity}" /></p>
            <p><strong>Date:</strong> <c:out value="${recentTicket.departureDateFormatted}" /></p>
            <p><strong>Time:</strong> <c:out value="${recentTicket.departureTimeFormatted}" /></p>
            <p><strong>Class:</strong> <c:out value="${recentTicket.travelClass}" /></p>
        </div>
    </c:if>
    <c:if test="${empty requestScope.recentTicket}">
        <p style="text-align:center; color:#555;">You have no recent ticket.</p>
    </c:if>

    <div style="text-align:center;">
        <button onclick="document.getElementById('overviewFormTable').submit();">Search</button>
    </div>
</body>
</html>
