<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Dawn Airlines</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f9f9f9;
      padding: 20px;
    }
    h1 { color: #333; }
    .form-section, .results, .ticket-card {
      margin-bottom: 30px;
      padding: 20px;
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    input, select, button {
      padding: 10px;
      margin: 5px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }
    button {
      background: #007BFF;
      color: white;
      cursor: pointer;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }
    th, td {
      border: 1px solid #ddd;
      padding: 12px;
      text-align: left;
    }
    th {
      background: #f1f1f1;
    }
    .ticket-card p {
      margin: 6px 0;
    }
  </style>
</head>

<body>

  <h1>Welcome, <c:out value="${sessionScope.user.fullName}" default="Guest"/></h1>

  <!-- Flight No. Search -->
  <div class="form-section">
    <h2>Search by Flight Number</h2>
    <form action="${pageContext.request.contextPath}/searchFlightByNumber" method="get">
      <input type="text" name="flightId" placeholder="Enter Flight No" required />
      <button type="submit">Search</button>
    </form>

    <!-- Display search result if present -->
    <c:if test="${not empty searchedFlight}">
      <div class="ticket-card">
        <p><strong>Flight ID:</strong> ${searchedFlight.flightId}</p>
        <p><strong>Route:</strong> ${searchedFlight.fromCity} → ${searchedFlight.toCity}</p>
        <p><strong>Date:</strong> ${searchedFlight.departureDate}</p>
        <p><strong>Time:</strong> ${searchedFlight.departureTime}</p>
        <p><strong>Class:</strong> ${searchedFlight.travelClass}</p>

        <form action="${pageContext.request.contextPath}/bookFlight" method="post">
          <input type="hidden" name="flightId" value="${searchedFlight.flightId}" />
          <button type="submit">Book This Flight</button>
        </form>
      </div>
    </c:if>

    <c:if test="${empty searchedFlight and param.flightId != null}">
      <p>No flight found for Flight ID: <strong>${param.flightId}</strong></p>
    </c:if>
  </div>

  <!-- From-To Search -->
  <div class="form-section">
    <h2>Find Flights by Route</h2>
    <form action="${pageContext.request.contextPath}/searchFlights" method="get">
      <input type="text" name="from" placeholder="From" required />
      <input type="text" name="to" placeholder="To" required />
      <input type="date" name="departureDate" required />
      <select name="travelClass">
        <option value="Economy">Economy</option>
        <option value="Business">Business</option>
      </select>
      <button type="submit">Search</button>
    </form>

    <!-- Matching flights table -->
    <c:if test="${not empty matchingFlights}">
      <table>
        <thead>
          <tr>
            <th>Flight ID</th>
            <th>Route</th>
            <th>Date</th>
            <th>Time</th>
            <th>Class</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <c:forEach var="flight" items="${matchingFlights}">
            <tr>
              <td>${flight.flightId}</td>
              <td>${flight.fromCity} → ${flight.toCity}</td>
              <td>${flight.departureDate}</td>
              <td>${flight.departureTime}</td>
              <td>${flight.travelClass}</td>
              <td>
                <form action="${pageContext.request.contextPath}/bookFlight" method="post">
                  <input type="hidden" name="flightId" value="${flight.flightId}" />
                  <button type="submit">Book</button>
                </form>
              </td>
            </tr>
          </c:forEach>
        </tbody>
      </table>
    </c:if>

    <c:if test="${empty matchingFlights and not empty param.from}">
      <p>No flights found from <strong>${param.from}</strong> to <strong>${param.to}</strong>.</p>
    </c:if>
  </div>

  <!-- Recent Ticket -->
  <c:if test="${not empty recentTicket}">
    <div class="form-section">
      <h2>Your Recent Ticket</h2>
      <div class="ticket-card">
        <p><strong>Booking Ref:</strong> ${recentTicket.bookingRef}</p>
        <p><strong>Flight:</strong> ${recentTicket.flightId} (${recentTicket.fromCity} → ${recentTicket.toCity})</p>
        <p><strong>Date:</strong> ${recentTicket.departureDate}</p>
        <p><strong>Class:</strong> ${recentTicket.travelClass}</p>
        <p><strong>Status:</strong> ${recentTicket.status}</p>

        <form action="${pageContext.request.contextPath}/cancelBooking" method="post">
          <input type="hidden" name="bookingRef" value="${recentTicket.bookingRef}" />
          <button type="submit" style="background:#dc3545;">Cancel Booking</button>
        </form>
      </div>
    </div>
  </c:if>

</body>
</html>
