<%@ page contentType="text/html;charset=UTF-8" language="java"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>${pageTitle}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    body { display: flex; margin: 0; font-family: Arial, sans-serif; background: #f0f2f5; }
    nav.sidebar {
      width: 200px; background: #2c3e50; color: #ecf0f1;
      padding: 20px 10px; box-sizing: border-box; height: 100vh;
    }
    nav.sidebar h2 { margin: 0 0 20px; font-size: 18px; text-align: center; }
    nav.sidebar a {
      display: block; color: #bdc3c7; text-decoration: none;
      padding: 8px 12px; border-radius: 4px; margin-bottom: 4px;
    }
    nav.sidebar a:hover { background: #34495e; color: white; }
    main.content {
      flex: 1; padding: 20px; overflow-y: auto;
    }

    /* Grid for cards */
    .cards { display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 30px; }
    .card {
      background: white; flex: 1 1 150px; padding: 15px;
      border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
      text-align: center;
    }
    .card h3 { margin: 0 0 10px; font-size: 16px; color: #333; }
    .card p { font-size: 24px; margin: 0; color: #111; }

    /* Charts */
    .charts { display: flex; flex-wrap: wrap; gap: 30px; margin-bottom: 30px; }
    .chart-box {
      background: white; padding: 15px; flex: 1 1 300px;
      border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .chart-box h3 { margin: 0 0 10px; font-size: 16px; color: #333; }
    .chart-box canvas { width: 100% !important; height: 300px !important; }

    /* Tables */
    table {
      width: 100%; border-collapse: collapse; background: white;
      margin-bottom: 30px; border-radius: 8px; overflow: hidden;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    th, td {
      padding: 10px; border-bottom: 1px solid #ddd; text-align: left;
    }
    th { background: #3498db; color: white; }
  </style>
</head>
<body>

<nav class="sidebar">
  <h2>Dawn Airlines</h2>
  <a href="staffDashboard?staffId=${param.staffId}">Dashboard</a>
  <a href="#">Staff</a>
  <a href="#">Attendance</a>
  <a href="#">Tasks</a>
  <a href="#">Performance</a>
  <a href="#">Flights</a>
  <a href="#">Passengers</a>
</nav>

<main class="content">
  <h1>${pageTitle}</h1>

  <!-- Summary Cards -->
  <div class="cards">
    <div class="card">
      <h3>Total Employees</h3>
      <p>${totalEmployees}</p>
    </div>
    <div class="card">
      <h3>Total Hours</h3>
      <p><fmt:formatNumber value="${totalHours}" maxFractionDigits="2"/></p>
    </div>
    <div class="card">
      <h3>Active Tasks</h3>
      <p>${activeTasks}</p>
    </div>
    <div class="card">
      <h3>Pending Tasks</h3>
      <p>${pendingTasks}</p>
    </div>
    <div class="card">
      <h3>Avg Rating</h3>
      <p><fmt:formatNumber value="${avgRating}" maxFractionDigits="1"/>%</p>
    </div>
    <div class="card">
      <h3>Total Flights</h3>
      <p>${totalFlights}</p>
    </div>
  </div>

  <!-- Charts -->
  <div class="charts">
    <div class="chart-box">
      <h3>Task Status Distribution</h3>
      <canvas id="taskChart"></canvas>
    </div>
    <div class="chart-box">
      <h3>Performance Distribution</h3>
      <canvas id="perfChart"></canvas>
    </div>
  </div>

  <!-- Recent Attendance -->
  <h2>Recent Attendance</h2>
  <table>
    <tr><th>Date</th><th>In</th><th>Out</th><th>Status</th><th>Hours</th></tr>
    <c:forEach var="a" items="${recentAttendance}">
      <tr>
        <td><fmt:formatDate value="${a.date}" pattern="yyyy-MM-dd"/></td>
        <td><fmt:formatDate value="${a.clockIn}" pattern="HH:mm"/></td>
        <td><fmt:formatDate value="${a.clockOut}" pattern="HH:mm"/></td>
        <td>${a.status}</td>
        <td><fmt:formatNumber value="${a.workingHours}" maxFractionDigits="2"/></td>
      </tr>
    </c:forEach>
  </table>

  <!-- Upcoming Flights -->
  <h2>Upcoming Flights</h2>
  <table>
    <tr><th>Flight #</th><th>Airline</th><th>From→To</th><th>Departure</th><th>Arrival</th></tr>
    <c:forEach var="f" items="${upcomingFlights}">
      <tr>
        <td>${f.flightNumber}</td>
        <td>${f.airline}</td>
        <td>${f.source}→${f.destination}</td>
        <td><fmt:formatDate value="${f.departureTime}" pattern="yyyy-MM-dd HH:mm"/></td>
        <td><fmt:formatDate value="${f.arrivalTime}" pattern="yyyy-MM-dd HH:mm"/></td>
      </tr>
    </c:forEach>
  </table>

  <!-- Charts Initialization -->
  <script>
    // Task Status Bar Chart
    const taskLabels = [<c:forEach var="k" items="${taskStatusCounts.keySet()}">'${k}',</c:forEach>];
    const taskData   = [<c:forEach var="v" items="${taskStatusCounts.values()}">${v},</c:forEach>];

    new Chart(document.getElementById('taskChart'), {
      type: 'bar',
      data: {
        labels: taskLabels,
        datasets: [{
          label: 'Tasks',
          data: taskData,
          backgroundColor: ['#3498db','#f1c40f','#e67e22','#e74c3c']
        }]
      },
      options: {
        scales: { y: { beginAtZero:true } }
      }
    });

    // Performance Pie Chart
    const perfLabels = [<c:forEach var="k" items="${performanceDistribution.keySet()}">'${k}',</c:forEach>];
    const perfData   = [<c:forEach var="v" items="${performanceDistribution.values()}">${v},</c:forEach>];

    new Chart(document.getElementById('perfChart'), {
      type: 'pie',
      data: {
        labels: perfLabels,
        datasets: [{
          data: perfData,
          backgroundColor: ['#2ecc71','#f39c12','#e74c3c','#95a5a6']
        }]
      }
    });
  </script>
</main>

</body>
</html>
