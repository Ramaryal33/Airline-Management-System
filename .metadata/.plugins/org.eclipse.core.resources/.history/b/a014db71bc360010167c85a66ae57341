<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Flights - Dawn Airlines</title>
  <style>
    /* ─── RESET & BASE STYLES ─────────────────────────────────────────────────── */
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Open Sans', Arial, sans-serif; }
    body { background: #f7f9fc; color: #333; padding: 20px; }
    h2 { margin-bottom: 20px; color: #2c3e50; text-align: center; }

    /* ─── SEARCH FORM ─────────────────────────────────────────────────────────── */
    .search-form { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 20px; }
    .search-form label { font-weight: bold; margin-top: 8px; }
    .search-form input[type="text"] { padding: 8px; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; flex: 1 1 200px; max-width: 300px; }
    .search-form button { padding: 8px 16px; background: #1976d2; color: #fff; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem; transition: background 0.3s; }
    .search-form button:hover { background: #145ca8; }

    /* ─── TABLE STYLES ────────────────────────────────────────────────────────── */
    .table-container { width: 100%; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; min-width: 600px; }
    th, td { padding: 12px; border: 1px solid #ddd; text-align: left; }
    th { background: #ecf0f1; font-weight: bold; }
    tr:hover { background: #f1f1f1; }

    /* ─── BOOK FORM ───────────────────────────────────────────────────────────── */
    .book-form { display: flex; align-items: center; flex-wrap: wrap; gap: 5px; }
    .book-form input[type="number"] { width: 60px; padding: 4px; border: 1px solid #ccc; border-radius: 4px; }
    .book-form button { background: #28a745; color: #fff; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; transition: background 0.3s; }
    .book-form button:hover { background: #1e7e34; }

    /* ─── EMPTY MESSAGE ───────────────────────────────────────────────────────── */
    .empty-message { text-align: center; color: #555; margin-top: 20px; font-size: 1rem; }

    /* ─── RESPONSIVE ADJUSTMENTS ───────────────────────────────────────────────── */
    @media (max-width: 480px) {
      .search-form { flex-direction: column; align-items: stretch; }
      .search-form input[type="text"] { max-width: 100%; }
      .search-form button { width: 100%; }
      table { min-width: auto; }
      th, td { padding: 8px; font-size: 0.9rem; }
      .book-form { flex-direction: column; align-items: stretch; }
      .book-form input[type="number"], .book-form button { width: 100%; }
    }
  </style>
</head>
<body>
  <h2>Available Flights</h2>

  <!-- Search form posts to /flight -->
  <form class="search-form" action="${pageContext.request.contextPath}/flight" method="post">
    <label for="flightId">Flight #:</label>
    <input id="flightId" type="text" name="flightId" placeholder="e.g. NP100" value="${fn:escapeXml(param.flightId)}" />
    <button type="submit">Search</button>
  </form>

  <!-- Flights table -->
  <c:if test="${not empty flights}">
    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>Flight #</th>
            <th>Route</th>
            <th>Date</th>
            <th>Time</th>
            <th>Class</th>
            <th>Price</th>
            <th>Book</th>
          </tr>
        </thead>
        <tbody>
          <c:forEach var="f" items="${flights}">
            <tr>
              <td><c:out value="${f.flightId}" /></td>
              <td><c:out value="${f.fromCity}" /> → <c:out value="${f.toCity}" /></td>
              <td><fmt:formatDate value="${f.departureDate}" pattern="MMM dd, yyyy" /></td>
              <td><fmt:formatDate value="${f.departureTime}" pattern="hh:mm a" /></td>
              <td><c:out value="${f.travelClass}" /></td>
              <td><fmt:formatNumber value="${f.price}" type="currency" currencySymbol="NPR " /></td>
              <td>
                <form class="book-form" action="${pageContext.request.contextPath}/createBooking" method="post">
                  <input type="hidden" name="flightId" value="${f.flightId}" />
                  Seats: <input type="number" name="numOfPassengers" value="1" min="1" required />
                  <button type="submit">Book</button>
                </form>
              </td>
            </tr>
          </c:forEach>
        </tbody>
      </table>
    </div>
  </c:if>

  <c:if test="${empty flights}">
    <div class="empty-message">No flights found.</div>
  </c:if>
</body>
</html>