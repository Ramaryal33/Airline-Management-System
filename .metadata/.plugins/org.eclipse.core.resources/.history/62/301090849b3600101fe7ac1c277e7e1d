package com.airline.controller;

import com.airline.model.Booking;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.HttpServlet;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import jakarta.servlet.http.HttpSession;

import java.io.IOException;

/**
 * Simulates payment for the booking stored in session as "selectedBooking".
 */
@SuppressWarnings("serial")
@WebServlet("/payment")
public class PaymentController extends HttpServlet {

    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        // Simply show payment.jsp
        HttpSession session = request.getSession(false);
        if (session == null || session.getAttribute("selectedBooking") == null) {
            response.sendRedirect(request.getContextPath() + "/searchFlights");
            return;
        }
        request.getRequestDispatcher("/WEB-INF/page/payment.jsp").forward(request, response);
    }

    @Override
    protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        Booking booking = (Booking) request.getSession().getAttribute("selectedBooking");
        if (booking == null) {
            response.sendRedirect(request.getContextPath() + "/searchFlights");
            return;
        }
        // In a real app, process cardNumber/expiry/cvv here. We'll just pretend it's successful.
        request.setAttribute("success", "Payment successful! Your booking is confirmed.");
        // Clear the booking from session so it cannot be paid again
        request.getSession().removeAttribute("selectedBooking");
        request.getRequestDispatcher("/WEB-INF/views/payment.jsp").forward(request, response);
    }
}
