package com.airline.controller;

import com.airline.service.PassengerService;
import com.airline.model.Flight;

import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.*;
import java.io.IOException;
import java.util.List;

@WebServlet("/searchFlight")
public class SearchFlightController extends HttpServlet {
    private PassengerService passengerService;

    @Override
    public void init() {
        passengerService = new PassengerService();
    }

    @Override
    protected void doPost(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {
        List<Flight> allFlights = passengerService.getAllFlights();
        request.setAttribute("allFlights", allFlights);
        request.getRequestDispatcher("/searchFlight.jsp").forward(request, response);
    }

    // GET just forwards to JSP for initial load
    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {
        List<Flight> allFlights = passengerService.getAllFlights();
        request.setAttribute("allFlights", allFlights);
        request.getRequestDispatcher("/searchFlight.jsp").forward(request, response);
    }
}
