package com.airline.controller;

import com.airline.staff.model.Attendance;
import com.airline.staff.model.Department;
import com.airline.staff.model.PerformanceReview;
import com.airline.staff.model.Staff;
import com.airline.staff.model.Task;
import com.airline.staff.service.AttendanceService;
import com.airline.staff.service.DepartmentService;
import com.airline.staff.service.PerformanceReviewService;
import com.airline.staff.service.StaffService;
import com.airline.staff.service.TaskService;

import jakarta.servlet.ServletException;
import jakarta.servlet.annotation.WebServlet;
import jakarta.servlet.http.*;

import java.io.IOException;
import java.util.List;

@WebServlet("/staffDashboard")
public class StaffDashboardController extends HttpServlet {
    private static final long serialVersionUID = 1L;

    private final StaffService             staffService            = new StaffService();
    private final AttendanceService        attendanceService       = new AttendanceService();
    private final TaskService              taskService             = new TaskService();
    private final PerformanceReviewService performanceReviewService = new PerformanceReviewService();
    private final DepartmentService        departmentService       = new DepartmentService();

    @Override
    protected void doGet(HttpServletRequest request, HttpServletResponse response)
            throws ServletException, IOException {

        // 1) session/login check
        HttpSession session = request.getSession(false);
        if (session == null || session.getAttribute("staff") == null) {
            response.sendRedirect(request.getContextPath() + "/login");
            return;
        }

        // 2) set common attributes
        request.setAttribute("pageTitle",       "Staff Dashboard - Dawn Airlines");
        request.setAttribute("cssPath",         request.getContextPath() + "/css/staff.css");
        request.setAttribute("logoPath",        request.getContextPath() + "/image/plane.png");
        request.setAttribute("profileImagePath",request.getContextPath() + "/image/login.jpg");
        request.setAttribute("basePath",        request.getContextPath());

        // 3) fetch logged‐in staffId
        Integer staffId = (Integer) session.getAttribute("staffId");
        if (staffId == null) {
            // as fallback, look up Staff by user object, or redirect
            response.sendRedirect(request.getContextPath() + "/login");
            return;
        }

        // 4) fetch all data
        Staff               staff       = staffService.getStaffById(staffId);
        List<Attendance>    attendances = attendanceService.getAllAttendances();
        List<Task>          tasks       = taskService.getAllTasks();
        List<PerformanceReview> reviews  = performanceReviewService.getAllReviews();
        List<Department>    depts       = departmentService.getAllDepartments();

        // 5) compute summary counts
        long presentCount     = attendances.stream().filter(a -> "Present".equalsIgnoreCase(a.getStatus())).count();
        long absentCount      = attendances.stream().filter(a -> "Absent".equalsIgnoreCase(a.getStatus())).count();
        long completedTasks   = tasks.stream().filter(t -> "Completed".equalsIgnoreCase(t.getStatus())).count();
        long pendingTasks     = tasks.stream().filter(t -> "Pending".equalsIgnoreCase(t.getStatus())).count();
        long inProgressTasks  = tasks.stream().filter(t -> "In Progress".equalsIgnoreCase(t.getStatus())).count();

        // 6) push to request
        request.setAttribute("staff",           staff);
        request.setAttribute("attendances",     attendances);
        request.setAttribute("tasks",           tasks);
        request.setAttribute("reviews",         reviews);
        request.setAttribute("departments",     depts);

        request.setAttribute("presentCount",    presentCount);
        request.setAttribute("absentCount",     absentCount);
        request.setAttribute("completedTasks",  completedTasks);
        request.setAttribute("pendingTasks",    pendingTasks);
        request.setAttribute("inProgressTasks", inProgressTasks);

        // 7) forward to JSP
        request.getRequestDispatcher("/WEB-INF/page/staffDashboard.jsp")
               .forward(request, response);
    }
}
