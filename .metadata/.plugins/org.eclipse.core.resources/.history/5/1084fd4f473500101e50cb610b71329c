<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<!DOCTYPE html>
<html>
<head>
    <title>Staff Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        h2 { color: #2c3e50; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
        th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
        th { background-color: #3498db; color: white; }
        .section { margin-bottom: 40px; }
    </style>
</head>
<body>

    <h1>Welcome, ${staff.firstName} ${staff.lastName}</h1>

    <!-- Staff Profile -->
    <div class="section">
        <h2>Profile Information</h2>
        <table>
            <tr><th>First Name</th><td>${staff.firstName}</td></tr>
            <tr><th>Last Name</th><td>${staff.lastName}</td></tr>
            <tr><th>Email</th><td>${staff.email}</td></tr>
            <tr><th>Phone</th><td>${staff.phone}</td></tr>
            <tr><th>Position</th><td>${staff.position}</td></tr>
            <tr><th>Department ID</th><td>${staff.departmentId}</td></tr>
            <tr><th>Hire Date</th><td>${staff.hireDate}</td></tr>
            <tr><th>Status</th><td>${staff.status}</td></tr>
        </table>
    </div>

    <!-- Tasks Summary -->
    <div class="section">
        <h2>Tasks Summary</h2>
        <table>
            <tr>
                <th>Task Status</th>
                <th>Count</th>
            </tr>
            <tr><td>Active</td><td>${activeTaskCount}</td></tr>
            <tr><td>Pending</td><td>${pendingTaskCount}</td></tr>
            <c:forEach var="entry" items="${taskStatusCounts}">
                <tr>
                    <td>${entry.key}</td>
                    <td>${entry.value}</td>
                </tr>
            </c:forEach>
        </table>

        <h3>Task Details</h3>
        <table>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th>Due Date</th>
            </tr>
            <c:forEach var="task" items="${tasks}">
                <tr>
                    <td>${task.title}</td>
                    <td>${task.description}</td>
                    <td>${task.status}</td>
                    <td><fmt:formatDate value="${task.dueDate}" pattern="yyyy-MM-dd"/></td>
                </tr>
            </c:forEach>
        </table>
    </div>

    <!-- Performance Reviews -->
    <div class="section">
        <h2>Performance Reviews</h2>
        <table>
            <tr>
                <th>Review Date</th>
                <th>Score</th>
                <th>Comments</th>
            </tr>
            <c:forEach var="review" items="${performanceReviews}">
                <tr>
                    <td><fmt:formatDate value="${review.reviewDate}" pattern="yyyy-MM-dd"/></td>
                    <td>${review.score}</td>
                    <td>${review.comments}</td>
                </tr>
            </c:forEach>
        </table>
    </div>

    <!-- Attendance Records -->
    <div class="section">
        <h2>Attendance Records</h2>
        <table>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Remarks</th>
            </tr>
            <c:forEach var="attendance" items="${attendances}">
                <tr>
                    <td><fmt:formatDate value="${attendance.date}" pattern="yyyy-MM-dd"/></td>
                    <td>${attendance.status}</td>
                    <td>${attendance.remarks}</td>
                </tr>
            </c:forEach>
        </table>
    </div>

</body>
</html>
