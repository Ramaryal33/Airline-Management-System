<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fn" uri="http://java.sun.com/jsp/jstl/functions" %>
<%
    //
    // ─── “Fake” DATA FOR DEMO ───────────────────────────────────────────────────────
    // We create a List<Map<String,String>> for tickets, and a single Map<String,String>
    // for recentTicket. In a real app, these would come from requestScope via a servlet.
    //
    java.util.List<java.util.Map<String,String>> sampleTickets = new java.util.ArrayList<>();
    {
        java.util.Map<String, String> t1 = new java.util.HashMap<>();
        t1.put("flightId",               "NP100");
        t1.put("departureDateFormatted", "Jun 06, 2024");
        t1.put("departureTimeFormatted", "03:00 PM");
        t1.put("travelClass",            "Economy");
        sampleTickets.add(t1);
        java.util.Map<String, String> t2 = new java.util.HashMap<>();
        t2.put("flightId",               "NP200");
        t2.put("departureDateFormatted", "Jun 07, 2024");
        t2.put("departureTimeFormatted", "09:30 AM");
        t2.put("travelClass",            "Business");
        sampleTickets.add(t2);
    }
    request.setAttribute("tickets", sampleTickets);

    java.util.Map<String, String> recent = new java.util.HashMap<>();
    recent.put("bookingRef",             "REF11395260");
    recent.put("flightId",               "NP100");
    recent.put("fromCity",               "Kathmandu");
    recent.put("toCity",                 "Bhairahawa");
    recent.put("departureDateFormatted", "Jun 06, 2024");
    recent.put("departureTimeFormatted", "03:00 PM");
    recent.put("travelClass",            "Economy");
    recent.put("status",                 "CONFIRMED");
    request.setAttribute("recentTicket", recent);
    //
    // ─────────────────────────────────────────────────────────────────────────────────
%>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - Dawn Airlines</title>
  <style>
    /* ─── RESET & BASE STYLES ─────────────────────────────────────────────────── */
    * {
      margin: 0; padding: 0; box-sizing: border-box;
      font-family: 'Open Sans', Arial, sans-serif;
    }
    body {
      background: #f7f9fc;
      color: #333;
      padding: 20px;
    }
    h1,h2,h3 { color: #2c3e50; margin-bottom: 15px; }
    hr { border: none; border-top: 1px solid #ddd; margin: 30px 0; }

    /* ─── SEARCH SECTION ───────────────────────────────────────────────────────── */
    .search-section {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 30px;
    }
    .search-section input[type="text"] {
      flex: 1;
      padding: 10px;
      border: 2px solid #ccc;
      border-radius: 6px;
      font-size: 1rem;
    }
    .search-section button {
      padding: 10px 20px;
      border: none;
      background: #1976d2;
      color: #fff;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      transition: background .3s;
    }
    .search-section button:hover {
      background: #145ca8;
    }

    /* ─── OVERVIEW TABLE ───────────────────────────────────────────────────────── */
    .overview-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 15px;
    }
    .overview-table th, .overview-table td {
      padding: 12px;
      border-bottom: 1px solid #ddd;
      text-align: left;
    }
    .overview-table th {
      background: #ecf0f1;
      font-weight: bold;
    }

    /* ─── TICKET CARD ──────────────────────────────────────────────────────────── */
    .ticket-card {
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      margin-bottom: 30px;
    }
    .ticket-card p {
      margin: 8px 0;
      font-size: 0.95rem;
    }
    .ticket-card p strong {
      color: #2c3e50;
    }

    /* ─── FLIGHT FINDER ────────────────────────────────────────────────────────── */
    .finder {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      margin-bottom: 30px;
    }
    .finder .trip-type {
      flex: 1 1 200px;
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      padding: 20px;
    }
    .finder .trip-type h3 {
      margin-bottom: 15px;
      font-size: 1rem;
      color: #2c3e50;
    }
    .finder .trip-type label {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 12px;
      font-size: 0.95rem;
      cursor: pointer;
    }
    .finder .trip-type input[type="radio"] {
      accent-color: #1976d2;
      transform: scale(1.2);
      margin-right: 4px;
    }

    .finder .finder-form {
      flex: 3 1 400px;
      background: #fff;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .finder-form .form-row {
      display: flex;
      gap: 15px;
      margin-bottom: 15px;
    }
    .finder-form .form-row input,
    .finder-form .form-row select {
      flex: 1;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 1rem;
    }
    .finder-form button {
      display: block;
      width: 100%;
      padding: 12px;
      border: none;
      background: #28a745;
      color: #fff;
      border-radius: 6px;
      font-size: 1rem;
      cursor: pointer;
      transition: background .3s, transform .2s;
    }
    .finder-form button:hover {
      background: #1e7e34;
      transform: scale(1.02);
    }

    /* ─── RESPONSIVE ───────────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .finder, .search-section {
        flex-direction: column;
      }
      .finder .trip-type {
        width: 100%;
      }
      .finder-form {
        width: 100%;
      }
      .overview-table, .ticket-card {
        font-size: 0.9rem;
      }
    }
  </style>

  <script>
    // ─── Trip‐Type Radio Logic ───────────────────────────────────────────────────
    function onTripTypeChange() {
      const oneWay = document.getElementById('tripOneWay').checked;
      const returnDateInput = document.getElementById('returnDate');
      if (oneWay) {
        returnDateInput.disabled = true;
        returnDateInput.value = '';
      } else {
        returnDateInput.disabled = false;
      }
    }
    function updateHiddenTripType() {
      const one = document.getElementById('tripOneWay').checked;
      document.getElementById('tripTypeHidden').value = one ? 'oneWay' : 'roundTrip';
    }
    window.addEventListener('DOMContentLoaded', function() {
      document.getElementById('tripOneWay').addEventListener('change', onTripTypeChange);
      document.getElementById('tripRoundTrip').addEventListener('change', onTripTypeChange);
      onTripTypeChange();

      document.getElementById('tripOneWay').addEventListener('change', updateHiddenTripType);
      document.getElementById('tripRoundTrip').addEventListener('change', updateHiddenTripType);
      updateHiddenTripType();
    });
  </script>
</head>
<body>
  <!--───────────────────────────────────────────────────-->
  <!-- 1) Welcome Header -->
  <!--───────────────────────────────────────────────────-->
  <h1>WELCOME, <c:out value="${sessionScope.user.fullName}" /></h1>

  <!--───────────────────────────────────────────────────-->
  <!-- 2) Search by Flight No. -->
  <!--───────────────────────────────────────────────────-->
  <div class="search-section">
    <form id="overviewForm" action="${pageContext.request.contextPath}/searchFlight" method="get">
      <input
        type="text"
        name="flightId"
        placeholder="Search by Flight No."
        value="${fn:escapeXml(param.flightId)}"
      />
      <button type="submit">Search</button>
    </form>
  </div>

  <!--───────────────────────────────────────────────────-->
  <!-- 3) Your Ticket Overview -->
  <!--───────────────────────────────────────────────────-->
  <h2>Your Ticket Overview</h2>
  <form id="overviewFormTable" action="${pageContext.request.contextPath}/searchFlight" method="get">
    <table class="overview-table">
      <thead>
        <tr>
          <th>Flight Number</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <c:forEach var="ticket" items="${requestScope.tickets}">
          <tr>
            <td><c:out value="${ticket.flightId}" /></td>
            <td><c:out value="${ticket.departureDateFormatted}" /></td>
          </tr>
        </c:forEach>
        <c:if test="${empty requestScope.tickets}">
          <tr>
            <td colspan="2" style="text-align:center; color:#555;">
              No tickets found.
            </td>
          </tr>
        </c:if>
      </tbody>
    </table>
  </form>
  <c:forEach var="ticket" items="${requestScope.tickets}">
    <div class="ticket-card">
      <p><strong>Time:</strong> <c:out value="${ticket.departureTimeFormatted}" /></p>
      <p><strong>Class:</strong> <c:out value="${ticket.travelClass}" /></p>
    </div>
  </c:forEach>

  <hr />

  <!--───────────────────────────────────────────────────-->
  <!-- 4) Find Your Flight (One‐Way / Round‐Trip) -->
  <!--───────────────────────────────────────────────────-->
  <h2>Find Your Flight</h2>
  <div class="finder">
    <!-- Trip Type Radios -->
    <div class="trip-type">
      <h3>Trip Type</h3>
      <label>
        <input
          type="radio"
          id="tripOneWay"
          name="tripType"
          value="oneWay"
          checked
        />
        One Way
      </label>
      <label>
        <input
          type="radio"
          id="tripRoundTrip"
          name="tripType"
          value="roundTrip"
        />
        Round Trip
      </label>
    </div>

    <!-- Flight Search Form -->
    <form
      class="finder-form"
      action="${pageContext.request.contextPath}/searchFlight"
      method="get"
    >
      <input type="hidden" name="tripTypeHidden" id="tripTypeHidden" />

      <div class="form-row">
        <input
          type="text"
          name="from"
          placeholder="From?"
          value="${fn:escapeXml(param.from)}"
        />
        <input
          type="text"
          name="to"
          placeholder="To?"
          value="${fn:escapeXml(param.to)}"
        />
      </div>
      <div class="form-row">
        <input
          type="date"
          name="departureDate"
          id="departureDate"
          value="${param.departureDate}"
          required
        />
        <input
          type="date"
          name="returnDate"
          id="returnDate"
          value="${param.returnDate}"
          ${param.tripTypeHidden == 'oneWay' ? 'disabled' : ''}
        />
      </div>
      <div class="form-row">
        <select name="travelClass">
          <option value="">Select Class</option>
          <option
            value="Economy"
            ${param.travelClass == 'Economy' ? 'selected' : ''}
          >Economy</option>
          <option
            value="Business"
            ${param.travelClass == 'Business' ? 'selected' : ''}
          >Business</option>
        </select>
        <input
          type="number"
          name="passengers"
          min="1"
          max="10"
          value="${param.passengers != null ? param.passengers : 1}"
        />
      </div>
      <button type="submit">Search Flights</button>
    </form>
  </div>

  <hr />

  <!--───────────────────────────────────────────────────-->
  <!-- 5) Your Recent Ticket -->
  <!--───────────────────────────────────────────────────-->
  <h2>Your Ticket</h2>
  <h3>Your Recent Ticket</h3>
  <c:choose>
    <c:when test="${not empty requestScope.recentTicket}">
      <div class="ticket-card">
        <p><strong>Booking Ref:</strong> <c:out value="${recentTicket.bookingRef}" /></p>
        <p><strong>Flight No:</strong> <c:out value="${recentTicket.flightId}" /></p>
        <p>
          <strong>Route:</strong>
          <c:out value="${recentTicket.fromCity}" /> →
          <c:out value="${recentTicket.toCity}" />
        </p>
        <p><strong>Date:</strong> <c:out value="${recentTicket.departureDateFormatted}" /></p>
        <p><strong>Time:</strong> <c:out value="${recentTicket.departureTimeFormatted}" /></p>
        <p><strong>Class:</strong> <c:out value="${recentTicket.travelClass}" /></p>
        <p><strong>Status:</strong> <c:out value="${recentTicket.status}" /></p>

        <!-- Cancel Booking Button -->
        <form
          action="${pageContext.request.contextPath}/cancelBooking"
          method="get"
          style="margin-top:12px;"
        >
          <input
            type="hidden"
            name="bookingRef"
            value="${fn:escapeXml(recentTicket.bookingRef)}"
          />
          <button
            type="submit"
            style="
              background:#e74c3c;
              color:white;
              padding:6px 12px;
              border:none;
              border-radius:4px;
              cursor:pointer;
            "
          >
            Cancel Booking
          </button>
        </form>
      </div>
    </c:when>
    <c:otherwise>
      <p style="text-align:center; color:#555;">
        You have no recent ticket.
      </p>
    </c:otherwise>
  </c:choose>

  <!--───────────────────────────────────────────────────-->
  <!-- 6) Footer “Search” button re‐submits the Overview Table form -->
  <!--───────────────────────────────────────────────────-->
  <div style="text-align:center; margin-top: 20px;">
    <button
      onclick="document.getElementById('overviewFormTable').submit();"
      style="
        padding: 8px 16px;
        font-size: 1rem;
        border: none;
        background: #1976d2;
        color: #fff;
        border-radius: 6px;
        cursor: pointer;
        transition: background .3s;
      "
      onmouseover="this.style.background='#145ca8';"
      onmouseout="this.style.background='#1976d2';"
    >
      Search
    </button>
  </div>
</body>
</html>
