<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard - Minimal Airline</title>
    <style>
        body {
            background: #f7f9fc;
            font-family: 'Open Sans', Arial, sans-serif;
            color: #333;
            padding: 20px;
        }
        h1, h2, h3 { margin-bottom: 15px; color: #2c3e50; }
        hr { border-top: 1px solid #ddd; margin: 30px 0; }

        /* Recent Ticket Card */
        .ticket-card {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }
        .ticket-card p { margin: 8px 0; font-size: 0.95rem; }

        /* Finder */
        .finder {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }
        .finder .form-row {
            display: flex;
            gap: 10px;
            margin-bottom: 15px;
        }
        .finder .form-row input,
        .finder .form-row select {
            flex: 1;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }
        .finder button {
            width: 100%;
            padding: 10px;
            border: none;
            background: #28a745;
            color: #fff;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            transition: background .3s;
        }
        .finder button:hover {
            background: #1e7e34;
        }

        @media (max-width: 600px) {
            .finder .form-row { flex-direction: column; }
        }
    </style>
</head>
<body>
    <h1>WELCOME, Guest (user_id = 1)</h1>

    <!-- Recent Ticket -->
    <h2>Your Recent Ticket</h2>
    <c:choose>
        <c:when test="${not empty requestScope.recentTicket}">
            <div class="ticket-card">
                <p><strong>Booking Ref:</strong> <c:out value="${recentTicket.bookingRef}" /></p>
                <p><strong>Flight No:</strong> <c:out value="${recentTicket.flightId}" /></p>
                <p>
                    <strong>Route:</strong>
                    <c:out value="${recentTicket.fromCity}" /> → <c:out value="${recentTicket.toCity}" />
                </p>
                <p><strong>Date:</strong> <c:out value="${recentTicket.departureDateFormatted}" /></p>
                <p><strong>Time:</strong> <c:out value="${recentTicket.departureTimeFormatted}" /></p>
                <p><strong>Class:</strong> <c:out value="${recentTicket.travelClass}" /></p>
            </div>
        </c:when>
        <c:otherwise>
            <p style="color:#555;">You have no recent ticket.</p>
        </c:otherwise>
    </c:choose>

    <hr />

    <!-- Find Your Flight Form -->
    <h2>Find Your Flight</h2>
    <div class="finder">
        <form action="${pageContext.request.contextPath}/searchFlights" method="get">
            <div class="form-row">
                <input type="text" name="from" placeholder="From (city)" />
                <input type="text" name="to"   placeholder="To (city)"   />
            </div>
            <div class="form-row">
                <input type="date"  name="departureDate" required />
                <select name="travelClass">
                    <option value="">Select Class</option>
                    <option value="Economy">Economy</option>
                    <option value="Business">Business</option>
                </select>
            </div>
            <button type="submit">Search Flights</button>
        </form>
    </div>
</body>
</html>
