<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib uri="http://java.sun.com/jsp/jstl/core" prefix="c" %>
<%@ page import="com.airline.staff.service.StaffService" %>
<%@ page import="com.airline.staff.service.TaskService" %>
<%@ page import="com.airline.staff.model.Staff" %>
<%@ page import="com.airline.staff.model.Task" %>
<%@ page import="java.util.List" %>



<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Staff Dashboard</title>
    <link rel="stylesheet" href="${pageContext.request.contextPath}/css/dashboard.css">
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background: #f7f9fc;
            color: #333;
        }

        h1 {
            text-align: center;
            color: #005bbb;
        }

        .metrics {
            display: flex;
            justify-content: space-around;
            margin: 30px 0;
        }

        .metric {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            width: 25%;
            text-align: center;
        }

        .metric h3 {
            margin-bottom: 10px;
            color: #777;
        }

        .metric p {
            font-size: 24px;
            font-weight: bold;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: white;
        }

        table th, table td {
            border: 1px solid #ccc;
            padding: 12px;
            text-align: center;
        }

        table th {
            background-color: #e6f2ff;
        }

        .bar-chart {
            width: 60%;
            margin: 40px auto;
        }

        .bar {
            background-color: #4caf50;
            height: 30px;
            margin: 10px 0;
            color: white;
            text-align: right;
            padding-right: 10px;
            border-radius: 5px;
            transition: width 0.5s ease;
        }

        .bar-label {
            margin-bottom: 5px;
            color: #333;
        }
    </style>
</head>
<body>

<h1>Welcome to Staff Dashboard</h1>

<div class="metrics">
    <div class="metric">
        <h3>Weekly Revenue</h3>
        <p>$<c:out value="${weeklyRevenue}" /></p>
    </div>
    <div class="metric">
        <h3>Total Passengers</h3>
        <p><c:out value="${totalPassengers}" /></p>
    </div>
    <div class="metric">
        <h3>Total Staff</h3>
        <p><c:out value="${totalStaff}" /></p>
    </div>
</div>

<h2>Staff Information</h2>
<table>
    <tr>
        <th>Name</th>
        <th>Position</th>
        <th>Email</th>
        <th>Phone</th>
    </tr>
    <c:forEach var="staff" items="${staffList}">
        <tr>
            <td>${staff.firstName} ${staff.lastName}</td>
            <td>${staff.position}</td>
            <td>${staff.email}</td>
            <td>${staff.phone}</td>
        </tr>
    </c:forEach>
</table>

<h2>Assigned Tasks</h2>
<table>
    <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Priority</th>
        <th>Due Date</th>
        <th>Progress</th>
    </tr>
    <c:forEach var="task" items="${taskList}">
        <tr>
            <td>${task.title}</td>
            <td>${task.status}</td>
            <td>${task.priority}</td>
            <td>${task.dueDate}</td>
            <td>${task.progress}%</td>
        </tr>
    </c:forEach>
</table>

<!-- Profit Margin Bar Chart -->
<h2 style="text-align:center; margin-top:40px;">Profit Margin by Department</h2>
<div class="bar-chart">
    <!-- Example static data. Replace with dynamic data using c:forEach -->
    <div class="bar-label">Operations - 75%</div>
    <div class="bar" style="width: 75%;">75%</div>

    <div class="bar-label">Sales - 60%</div>
    <div class="bar" style="width: 60%;">60%</div>

    <div class="bar-label">Maintenance - 45%</div>
    <div class="bar" style="width: 45%;">45%</div>

    <div class="bar-label">Customer Support - 35%</div>
    <div class="bar" style="width: 35%;">35%</div>
</div>

</body>
</html>
