<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Booking Confirmation - Minimal Airline</title>
    <style>
        body {
            background: #f7f9fc;
            font-family: 'Open Sans', Arial, sans-serif;
            color: #333;
            padding: 40px;
        }
        .confirmation-box {
            background: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: auto;
            text-align: center;
        }
        .confirmation-box h2 {
            color: #2c3e50;
            margin-bottom: 20px;
        }
        .confirmation-box p {
            margin: 12px 0;
            font-size: 1rem;
        }
        .booking-ref {
            font-size: 1.2rem;
            font-weight: bold;
            color: #1976d2;
            margin: 15px 0;
        }
        .flight-summary {
            background: #fafafa;
            padding: 20px;
            text-align: left;
            border-radius: 6px;
            margin: 20px 0;
        }
        .flight-summary p {
            margin: 6px 0;
        }
        .summary-price {
            font-weight: bold;
            margin-top: 10px;
            color: #1976d2;
        }
        .btn-continue {
            background: #28a745;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.3s;
        }
        .btn-continue:hover {
            background: #1e7e34;
        }
    </style>
</head>
<body>
    <div class="confirmation-box">
        <h2>Booking Confirmed!</h2>

        <c:choose>
            <c:when test="${empty sessionScope.selectedBooking}">
                <p>Oops! No booking found. Please try again.</p>
                <a href="${pageContext.request.contextPath}/searchFlights" class="btn-continue">Back to Search</a>
            </c:when>
            <c:otherwise>
                <c:set var="b" value="${sessionScope.selectedBooking}" />
                <!-- We need flight details: re‐fetch in JSP for simplicity -->
                <jsp:useBean id="fService" class="com.airline.service.FlightService" scope="page"/>
                <c:set var="flight" value="${fService.getFlightById(b.flightId)}" />

                <p>Your booking reference is:</p>
                <div class="booking-ref"><c:out value="${b.bookingRef}" /></div>

                <div class="flight-summary">
                    <p><strong>Flight No:</strong> <c:out value="${b.flightId}" /></p>
                    <p><strong>Route:</strong> <c:out value="${flight.fromCity}" /> → <c:out value="${flight.toCity}" /></p>
                    <p>
                        <strong>Date:</strong>
                        <fmt:formatDate value="${flight.departureDate}" pattern="MMM dd, yyyy" /><br/>
                        <strong>Time:</strong>
                        <fmt:formatDate value="${flight.departureTime}" pattern="hh:mm a" />
                    </p>
                    <p><strong>Class:</strong> <c:out value="${flight.travelClass}" /></p>
                    <p class="summary-price">
                        Total Paid:
                        <fmt:formatNumber value="${b.totalPrice}" type="currency" currencySymbol="NPR " />
                    </p>
                </div>

                <a href="${pageContext.request.contextPath}/payment" class="btn-continue">Proceed to Payment</a>
            </c:otherwise>
        </c:choose>
    </div>
</body>
</html>
