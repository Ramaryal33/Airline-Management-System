<%@ page contentType="text/html; charset=UTF-8" language="java" %>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Cancel Booking - Dawn Airlines</title>
    <style>
        * {
            margin: 0; padding: 0; box-sizing: border-box;
            font-family: 'Open Sans', Arial, sans-serif;
        }
        body {
            display: flex;
            min-height: 100vh;
            background: #f7f9fc;
            color: #333;
        }

        .sidebar {
            position: fixed;
            top: 0; left: 0;
            width: 250px;
            height: 100vh;
            padding: 20px;
            color: #ecf0f1;
            background: linear-gradient(135deg, #2c3e50, #3d566e);
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .sidebar img.logo {
            width: 100px;
            margin-bottom: 50px;
            border-radius: 50%;
        }
        .sidebar nav {
            width: 100%;
            text-align: center;
        }
        .sidebar nav a {
            display: block;
            color: #ecf0f1;
            text-decoration: none;
            padding: 12px;
            margin: 8px 0;
            font-weight: bold;
            border-radius: 6px;
            transition: all 0.3s;
        }
        .sidebar nav a:hover,
        .sidebar nav a.active {
            background: rgba(255, 255, 255, 0.1);
            transform: translateX(5px);
        }
        .sidebar .bottom {
            margin-top: auto;
        }

        .main {
            margin-left: 250px;
            padding: 40px;
            flex: 1;
        }

        .cancel-card {
            background: #fff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            max-width: 700px;
            margin: auto;
        }
        .cancel-card h2 {
            color: #0a1c2c;
            margin-bottom: 20px;
        }
        .info-list {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }
        .info-list .left-info,
        .info-list .right-info {
            flex: 1;
            background: #fafafa;
            padding: 15px;
            border-radius: 8px;
        }
        .info-list p {
            margin: 8px 0;
            color: #555;
        }
        .info-list hr {
            margin: 15px 0;
            border: 0;
            border-top: 1px solid #ddd;
        }
        .info-list .right-info p {
            font-weight: bold;
        }
        .info-list .right-info p.refund {
            margin-top: 10px;
            color: #1976d2;
        }

        label {
            display: block;
            margin: 15px 0 8px;
            font-weight: bold;
        }
        select {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }
        .confirm-box {
            margin: 15px 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .confirm-box label {
            margin: 0;
            font-weight: normal;
            color: #555;
        }
        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }
        .button-group button {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-size: 1rem;
            cursor: pointer;
            transition: background .3s, transform .2s;
        }
        .cancel-booking {
            background: #e74c3c;
            color: #fff;
        }
        .cancel-booking:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
        .cancel-booking:hover:not(:disabled) {
            background: #c0392b;
            transform: scale(1.02);
        }
        .go-back {
            background: #3498db;
            color: #fff;
        }
        .go-back:hover {
            background: #2980b9;
            transform: scale(1.02);
        }

        @media(max-width: 900px) {
            .sidebar {
                position: static;
                width: 100%;
                flex-direction: row;
                justify-content: space-around;
                flex-wrap: wrap;
                height: auto;
                padding: 10px;
            }
            .main {
                margin-left: 0;
                padding: 20px;
            }
            .info-list {
                flex-direction: column;
            }
        }
    </style>
    <script>
        function enableCancelButton() {
            const check = document.getElementById('confirm');
            const btn = document.getElementById('cancel-btn');
            btn.disabled = !check.checked;
        }
    </script>
</head>
<body>
    <!-- SIDEBAR -->
    <div class="sidebar">
        <img src="${pageContext.request.contextPath}/plane.png" class="logo" alt="Airline Logo" />
        <nav>
            <a href="${pageContext.request.contextPath}/passengerDashboard">Dashboard</a>
            <a href="${pageContext.request.contextPath}/searchFlights">Search Flights</a>
            <a href="${pageContext.request.contextPath}/payment">Payment</a>
            <a href="${pageContext.request.contextPath}/cancelBooking" class="active">Cancel Bookings</a>
            <a href="${pageContext.request.contextPath}/contact">Contact Us</a>
            <a href="${pageContext.request.contextPath}/logout">Log out</a>
            <div class="bottom">
                <a href="${pageContext.request.contextPath}/passengerProfile">Settings</a>
            </div>
        </nav>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main">
        <div class="cancel-card">
            <h2>Cancel Booking</h2>

            <c:choose>
                <!-- If no bookedFlight in session or no user -->
                <c:when test="${empty sessionScope.bookedFlight or empty sessionScope.user or empty sessionScope.bookingRef}">
                    <p style="text-align:center; color:#555;">
                        You have no active booking to cancel.
                    </p>
                    <div style="text-align:center; margin-top:20px;">
                        <button class="go-back" onclick="location.href='${pageContext.request.contextPath}/passengerDashboard'">
                            Go Back
                        </button>
                    </div>
                </c:when>

                <!-- Otherwise, show cancellation info -->
                <c:otherwise>
                    <div class="info-list">
                        <div class="left-info">
                            <p><strong>Name:</strong> <c:out value="${sessionScope.user.fullName}" /></p>
                            <p><strong>Booking Ref:</strong> <c:out value="${sessionScope.bookingRef}" /></p>
                            <p><strong>Flight Number:</strong> <c:out value="${sessionScope.bookedFlight.flightId}" /></p>
                            <p><strong>From:</strong> <c:out value="${sessionScope.bookedFlight.fromCity}" /></p>
                            <p><strong>To:</strong> <c:out value="${sessionScope.bookedFlight.toCity}" /></p>
                            <p><strong>Date:</strong> <c:out value="${sessionScope.bookedFlight.departureDateFormatted}" /></p>
                            <p><strong>Time:</strong> <c:out value="${sessionScope.bookedFlight.departureTimeFormatted}" /></p>
                            <p><strong>Class:</strong> <c:out value="${sessionScope.bookedFlight.travelClass}" /></p>
                        </div>
                        <div class="right-info">
                            <p><strong>Ticket Price:</strong> 
                                <fmt:formatNumber value="${sessionScope.bookedFlight.price}" type="currency" currencySymbol="NPR " />
                            </p>
                            <p><strong>Cancellation Fee:</strong> 
                                <fmt:formatNumber value="${sessionScope.cancellationFee}" type="currency" currencySymbol="NPR " />
                            </p>
                            <hr />
                            <p class="refund">
                                <strong>Refund Amount:</strong> 
                                <fmt:formatNumber 
                                    value="${sessionScope.bookedFlight.price - sessionScope.cancellationFee}" 
                                    type="currency" currencySymbol="NPR " 
                                />
                            </p>
                        </div>
                    </div>

                    <form method="post" action="${pageContext.request.contextPath}/cancelBooking">
                        <label for="reason">Select reason for cancellation:</label>
                        <select name="reason" id="reason" required>
                            <option value="">CHOOSE REASON…</option>
                            <option value="Schedule issues">Schedule issues</option>
                            <option value="Health issue">Health issue</option>
                            <option value="Family issue">Family issue</option>
                            <option value="Changed plans">Changed plans</option>
                            <option value="Service issues">Service issues</option>
                            <option value="Personal">Personal</option>
                            <option value="Other">Other</option>
                        </select>

                        <div class="confirm-box">
                            <input type="checkbox" id="confirm" name="confirm" value="yes" onchange="enableCancelButton()" />
                            <label for="confirm">Are you sure you want to cancel this flight?</label>
                        </div>

                        <div class="button-group">
                            <button id="cancel-btn" class="cancel-booking" type="submit" disabled>
                                Cancel Booking
                            </button>
                            <button type="button" class="go-back"
                                    onclick="location.href='${pageContext.request.contextPath}/passengerDashboard'">
                                Go Back
                            </button>
                        </div>
                    </form>
                </c:otherwise>
            </c:choose>
        </div>
    </div>
</body>
</html>
